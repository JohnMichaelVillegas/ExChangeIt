<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExChangeIt.MainPage"
             BackgroundColor="#F5F7FB">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label Text="ValuEx"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#1F2937"
                       HorizontalOptions="Center" />

                <Label Text="Fast and simple currency conversion"
                       FontSize="14"
                       TextColor="#6B7280"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Border BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">

                <VerticalStackLayout Spacing="18">

                    <Label Text="Currency Converter"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Base Currency"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Border BackgroundColor="#F9FAFB"
                                Stroke="#D1D5DB"
                                StrokeShape="RoundRectangle 12"
                                Padding="10,4">
                            <Picker x:Name="basePicker"
                                    Title="Select base currency"
                                    TextColor="#111827" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Target Currency"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Border BackgroundColor="#F9FAFB"
                                Stroke="#D1D5DB"
                                StrokeShape="RoundRectangle 12"
                                Padding="10,4">
                            <Picker x:Name="targetPicker"
                                    Title="Select target currency"
                                    TextColor="#111827" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Amount"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#374151" />
                        <Border BackgroundColor="#F9FAFB"
                                Stroke="#D1D5DB"
                                StrokeShape="RoundRectangle 12"
                                Padding="12,2">
                            <Entry x:Name="amountEntry"
                                   Placeholder="Enter amount"
                                   Keyboard="Numeric"
                                   TextColor="#111827"
                                   PlaceholderColor="#9CA3AF"
                                   FontSize="16" />
                        </Border>
                    </VerticalStackLayout>

                    <Button x:Name="convertButton"
                            Text="Convert"
                            Clicked="OnConvertClicked"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52" />

                    <Button Text="Show Live Rates"
                            Clicked="OnShowRatesClicked"
                            BackgroundColor="#4B3F72"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="52" />

                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <ActivityIndicator x:Name="loadingIndicator"
                                           IsVisible="False"
                                           IsRunning="False"
                                           Color="#4F46E5" />

                        <Label x:Name="statusLabel"
                               Text=""
                               FontSize="13"
                               TextColor="#4F46E5"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               IsVisible="False" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">

                <VerticalStackLayout Spacing="16">

                    <Label Text="Conversion Result"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Border BackgroundColor="#EEF2FF"
                            Stroke="#C7D2FE"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Exchange Rate"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#4338CA" />
                            <Label x:Name="rateLabel"
                                   Text="Rate will appear here"
                                   FontSize="16"
                                   TextColor="#1F2937" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#ECFDF5"
                            Stroke="#A7F3D0"
                            StrokeShape="RoundRectangle 14"
                            Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Converted Amount"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#047857" />
                            <Label x:Name="resultLabel"
                                   Text="Converted amount will appear here"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>